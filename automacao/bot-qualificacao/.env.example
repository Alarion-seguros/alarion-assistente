# ─── Variáveis de Ambiente — Bot de Qualificação (WhatsApp / Z-API) ──────────
# Copie este ficheiro para .env e preencha os valores antes de iniciar o serviço.
# NUNCA faça commit do ficheiro .env com valores reais.

# ── Servidor HTTP / Webhook ──────────────────────────────────────────────────
# Porta em que o servidor de webhook irá escutar.
PORT=3100
# Caminho do endpoint que recebe as mensagens da Z-API.
WEBHOOK_PATH=/webhook
# (Opcional) Token de segurança exigido na query string do webhook (?token=...).
# Se definido, configure a mesma string no URL do webhook no painel da Z-API.
WEBHOOK_TOKEN=

# ── Credenciais Z-API ────────────────────────────────────────────────────────
# Obtenha estes valores no painel da Z-API (https://app.z-api.io), na sua instância.
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
# Account Security Token (Client-Token). Necessário se estiver ativado no painel.
ZAPI_CLIENT_TOKEN=
# Base da API Z-API (normalmente não precisa alterar).
ZAPI_BASE_URL=https://api.z-api.io
# Atraso (ms) entre mensagens consecutivas enviadas ao mesmo contacto.
SEND_DELAY_MS=1200

# ── Armazenamento ────────────────────────────────────────────────────────────
# Diretório onde o ficheiro Excel de leads será gravado.
DATA_DIR=./data
# Caminho completo do ficheiro Excel (sobrepõe DATA_DIR se definido).
# EXCEL_PATH=./data/leads_qualificados.xlsx

# ── Sessões ──────────────────────────────────────────────────────────────────
# Tempo (ms) de inatividade após o qual a conversa reinicia do início (padrão: 6h).
SESSAO_TTL_MS=21600000

# ── Logs ─────────────────────────────────────────────────────────────────────
LOG_DIR=./logs
