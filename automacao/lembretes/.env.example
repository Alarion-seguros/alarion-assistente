# ─── Variáveis de Ambiente — Agendador de Lembretes de Boletos ───────────────
# Copie este ficheiro para .env e preencha os valores antes de iniciar o serviço.
# NUNCA faça commit do ficheiro .env com valores reais.

# URL base da API tRPC do sistema Alarion (obrigatória em produção)
# Exemplo: https://app.alarion.com.br/api/trpc
TRPC_BASE_URL=http://localhost:3000/api/trpc

# Token de autenticação interno para chamadas à API tRPC (obrigatório em produção)
# Gere um token seguro e configure-o também no backend.
TRPC_INTERNAL_TOKEN=

# Tempo limite (em milissegundos) para aguardar resposta da API (padrão: 30000)
TRPC_TIMEOUT_MS=30000

# Número máximo de tentativas em caso de falha transitória (padrão: 3)
MAX_RETRIES=3

# Atraso base entre tentativas em ms — backoff linear crescente (padrão: 5000)
RETRY_DELAY_MS=5000

# Diretório onde os ficheiros de log serão gravados (padrão: ./logs)
LOG_DIR=./logs
